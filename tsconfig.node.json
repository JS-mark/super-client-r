{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["ESNext"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"noEmit": true,
		"composite": true,
		"skipLibCheck": true,
		"types": ["node"],
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"strictPropertyInitialization": false,
		"baseUrl": ".",
		"paths": {
			"@super-client/shared-types": ["./packages/shared-types/src"],
			"@super-client/shared-types/*": ["./packages/shared-types/src/*"]
		}
	},
	"include": ["src/main", "src/preload", "electron.vite.config.ts", "packages/shared-types/src"]
}
