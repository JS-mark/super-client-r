{
  "name": "super-client-r",
  "version": "0.0.1",
  "description": "A super client application built with Electron, React and Ant Design",
  "author": "Mark",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.24.0",
  "main": "out/main/main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "tsc -b && electron-vite dev",
    "build": "tsc -b && electron-vite build && electron-builder",
    "build:mac": "tsc -b && electron-vite build && electron-builder --mac",
    "build:win": "tsc -b && electron-vite build && electron-builder --win",
    "build:icons": "tsx scripts/build-icons.ts",
    "release": "tsx scripts/release.ts",
    "lint": "oxlint .",
    "lint:biome": "biome lint .",
    "format": "biome format --write .",
    "check:biome": "biome check --write .",
    "preview": "electron-vite preview",
    "check": "tsc -b --noEmit",
    "i18n:check": "tsx scripts/i18n/check.ts",
    "i18n:translate": "tsx scripts/i18n/translate.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "docs:dev": "pnpm --filter @super-client/docs dev",
    "docs:build": "pnpm --filter @super-client/docs build",
    "docs:preview": "pnpm --filter @super-client/docs preview",
    "agent:build": "pnpm --filter @super-client/device-agent build",
    "agent:build:all": "pnpm --filter @super-client/device-agent build:all",
    "relay:build": "pnpm --filter @super-client/relay-server build",
    "relay:build:all": "pnpm --filter @super-client/relay-server build:all",
    "relay:start": "pnpm --filter @super-client/relay-server start"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.82",
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/azure": "^3.0.48",
    "@ai-sdk/cerebras": "^2.0.41",
    "@ai-sdk/gateway": "^3.0.77",
    "@ai-sdk/google": "^3.0.52",
    "@ai-sdk/google-vertex": "^4.0.93",
    "@ai-sdk/huggingface": "^1.0.39",
    "@ai-sdk/mistral": "^3.0.27",
    "@ai-sdk/openai": "^3.0.47",
    "@ai-sdk/perplexity": "^3.0.25",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/provider-utils": "^4.0.21",
    "@ai-sdk/test-server": "^1.0.3",
    "@ai-sdk/xai": "3.0.57",
    "@ant-design/icons": "^6.1.0",
    "@ant-design/x": "^2.4.0",
    "@ant-design/x-markdown": "^2.4.0",
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@anthropic-ai/sdk": "^0.78.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@google/genai": "^1.46.0",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.4.0",
    "@langchain/core": "^1.1.34",
    "@langchain/openai": "^1.3.0",
    "@langchain/textsplitters": "^1.0.1",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@melloware/react-logviewer": "^6.4.1",
    "@milkdown/crepe": "^7.19.0",
    "@milkdown/kit": "^7.19.0",
    "@milkdown/react": "^7.19.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@super-client/shared-types": "workspace:*",
    "@uiw/codemirror-extensions-langs": "^4.25.8",
    "@uiw/codemirror-theme-vscode": "^4.25.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.134",
    "antd": "^6.3.3",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "dingtalk-stream": "^2.1.5",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "emoji-picker-element": "^1.29.1",
    "emoji-picker-element-data": "^1.8.0",
    "fs-extra": "^11.3.4",
    "get-port": "^7.1.0",
    "google-auth-library": "^10.6.2",
    "i18next": "^25.9.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "koa": "^3.1.2",
    "koa-bodyparser": "^4.4.1",
    "koa-proxies": "^0.12.4",
    "koa-swagger-decorator": "^1.8.7",
    "lucide-react": "^0.564.0",
    "md5": "^2.3.0",
    "mermaid": "^11.13.0",
    "mime": "^4.1.0",
    "mime-types": "^3.0.2",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "node-telegram-bot-api": "^0.66.0",
    "oauth-1.0a": "^2.2.6",
    "openai": "^6.32.0",
    "pyodide": "^0.29.3",
    "quickjs-emscripten": "^0.32.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "react-window": "^2.2.7",
    "react18-json-view": "^0.2.9",
    "swagger-ui-dist": "^5.32.1",
    "tailwind-merge": "^3.5.0",
    "tinyglobby": "^0.2.15",
    "undici": "^7.24.5",
    "ws": "^8.19.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/koa": "^3.0.2",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/koa-router": "^7.4.9",
    "@types/koa__cors": "^5.0.1",
    "@types/koa__router": "^12.0.5",
    "@types/node": "^25.5.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-dev-locator": "^1.0.6",
    "bun": "^1.3.11",
    "chalk": "^5.6.2",
    "code-inspector-plugin": "^1.4.5",
    "dotenv": "^17.3.1",
    "electron": "^38.8.6",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^28.1.0",
    "oxlint": "^1.56.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "rolldown": "1.0.0-rc.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^7.3.1",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  },
  "build": {
    "appId": "com.superclient.app",
    "productName": "Super Client",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "build/icons/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "js-mark",
        "repo": "super-client-r"
      }
    ],
    "mac": {
      "electronLanguages": [
        "en",
        "zh_CN"
      ],
      "icon": "build/icons/icon.icns",
      "category": "com.superclient.app",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "icon": "build/icons/icon.icns",
      "iconSize": 128,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Super Client"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@scarf/scarf",
      "better-sqlite3",
      "bun",
      "msw",
      "protobufjs"
    ]
  }
}
