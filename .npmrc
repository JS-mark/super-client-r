# Note: electron_mirror intentionally NOT set in project .npmrc
# - npmmirror lacks electron-builder-binaries (dmg-builder), causing build failures
# - Set electron_mirror in your ~/.npmrc if needed for local development
engine-strict=true

# Allow bun postinstall script to run (required for relay-server and device-agent builds)
only-built-dependencies[]=bun
only-built-dependencies[]=better-sqlite3
